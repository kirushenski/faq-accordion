{
  "name": "faq-accordion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:ts:ci": "eslint .",
    "lint:ts": "npm run lint:ts:ci -- --fix",
    "lint:css:ci": "stylelint '**/*.css' --ignore-path .gitignore",
    "lint:css": "npm run lint:css:ci -- --fix",
    "lint:format:ci": "prettier . --check",
    "lint:format": "npm run lint:format:ci -- --write",
    "lint": "npm run lint:ts && npm run lint:css && npm run lint:format",
    "type-check": "tsc",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint && npm run type-check && npm run test:coverage",
    "check-updates": "npx npm-check-updates -i --format group"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "engines": {
    "node": "^24",
    "yarn": "please, use npm to install dependencies!"
  },
  "dependencies": {
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "clsx": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.2",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.4"
  }
}
